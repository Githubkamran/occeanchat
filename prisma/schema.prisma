generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./oceanchat.db"
}

model Account {
  username     String   @id
  usernameKey  String   @unique
  passSalt     String
  passHash     String
  gender       String
  targetGender String
  age          Int      @default(0)
  region       String   @default("")
  createdAt    DateTime @default(now())
}
